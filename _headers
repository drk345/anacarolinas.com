# Cloudflare Pages headers
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data:; font-src 'self'; style-src 'self'; script-src 'self'; connect-src 'self'; form-action 'self'; upgrade-insecure-requests

# HTML pages: always revalidate so visitors get fresh content on every deploy
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/programas.html
  Cache-Control: no-cache
/sesiones-individuales.html
  Cache-Control: no-cache
/conecta.html
  Cache-Control: no-cache
/foco.html
  Cache-Control: no-cache
/intensivo.html
  Cache-Control: no-cache
/sobre-ana.html
  Cache-Control: no-cache
/contacto.html
  Cache-Control: no-cache
/privacidad.html
  Cache-Control: no-cache

# Content-addressable, rarely-changing assets: cache hard
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS: short cache during active launch period; bump ?v=N on editorial.css when CSS changes
/assets/css/*
  Cache-Control: public, max-age=3600, must-revalidate
/assets/js/*
  Cache-Control: public, max-age=3600, must-revalidate
